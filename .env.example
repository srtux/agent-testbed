# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
PROJECT_ID=your-project-id
CLUSTER_NAME=default-cluster
CUSTOM_DOMAIN=testbed.example.com
TF_STATE_BUCKET=your-project-id-tf-state

# OpenTelemetry Configuration
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# Agent Service URLs
ROOT_ROUTER_URL=http://localhost:8080/chat
BOOKING_ORCHESTRATOR_URL=http://localhost:8081/chat
FLIGHT_SPECIALIST_URL=http://localhost:8082/chat
WEATHER_SPECIALIST_URL=http://localhost:8083/chat
HOTEL_SPECIALIST_URL=http://localhost:8084/chat
CAR_RENTAL_SPECIALIST_URL=http://localhost:8085/chat

# MCP Server URLs
PROFILE_MCP_URL=http://localhost:8090/sse
INVENTORY_MCP_URL=http://localhost:8091/sse
